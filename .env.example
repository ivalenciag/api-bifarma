# Clave que protege todos los endpoints (header x-api-key).
# Genera una con: openssl rand -hex 32
API_KEY=change_me

# PORT lo inyecta Render automaticamente -- no lo definas aqui.

# BIFARMA_USER y BIFARMA_PASSWORD ya no se usan.
# Las credenciales del portal Bifarma llegan por request
# (headers x-bifarma-user y x-bifarma-password).
