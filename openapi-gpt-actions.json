{
  "openapi": "3.1.0",
  "info": {
    "title": "Bifarma Connector API",
    "version": "2.7.0",
    "description": "API para consultar informes privados de Bifarma/AtlasSBI desde un GPT personalizado. Usa autenticacion mediante header x-api-key."
  },
  "servers": [
    {
      "url": "https://bifarma-api.onrender.com",
      "description": "Render"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "GenericObject": {
        "type": "object",
        "description": "Respuesta JSON flexible de la API. Puede incluir campos adicionales segun el endpoint.",
        "properties": {
          "message": {
            "type": "string",
            "description": "Mensaje descriptivo cuando la respuesta lo incluya."
          },
          "code": {
            "type": "string",
            "description": "Codigo del informe cuando la respuesta lo incluya."
          },
          "rows": {
            "type": "array",
            "description": "Filas de datos extraidas cuando la respuesta corresponda a un informe.",
            "items": {
              "type": "object",
              "properties": {
                "row_index": {
                  "type": "integer"
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "available": {
            "type": "boolean"
          },
          "authenticated": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "ReportFieldInfo": {
        "type": "object",
        "properties": {
          "tag": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "value_preview": {
            "type": "string"
          },
          "value_length": {
            "type": "integer"
          },
          "text": {
            "type": "string"
          },
          "class": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "placeholder": {
            "type": "string"
          },
          "aria_label": {
            "type": "string"
          },
          "onclick": {
            "type": "string"
          },
          "disabled": {
            "type": "boolean"
          },
          "readonly": {
            "type": "boolean"
          },
          "checked": {
            "type": "boolean"
          },
          "label_text": {
            "type": "string"
          },
          "nearby_text": {
            "type": "string"
          },
          "unique_id": {
            "type": "string"
          },
          "client_instance_name": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "ReportFormDebugResponse": {
        "type": "object",
        "properties": {
          "opened": {
            "type": "boolean"
          },
          "code": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "report_index": {
            "type": "integer"
          },
          "report_type": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "role_id": {
            "type": "string"
          },
          "report_url": {
            "type": "string"
          },
          "status_code": {
            "type": "integer"
          },
          "final_url": {
            "type": "string"
          },
          "page_title": {
            "type": "string"
          },
          "form_analysis": {
            "type": "object",
            "properties": {
              "forms": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "hidden_inputs": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ReportFieldInfo"
                }
              },
              "visible_inputs": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ReportFieldInfo"
                }
              },
              "selects": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ReportFieldInfo"
                }
              },
              "textareas": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ReportFieldInfo"
                }
              },
              "related_fields": {
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ReportFieldInfo"
                  }
                }
              },
              "buttons_or_callbacks_related_to_update": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ReportFieldInfo"
                }
              },
              "devexpress_controls": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "relevant_script_lines": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "counts": {
                "type": "object",
                "additionalProperties": {
                  "type": "integer"
                }
              }
            },
            "additionalProperties": true
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "home",
        "summary": "Comprobar que la API responde",
        "responses": {
          "200": {
            "description": "API funcionando",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObject"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/status": {
      "get": {
        "operationId": "getStatus",
        "summary": "Ver estado de la API",
        "responses": {
          "200": {
            "description": "Estado de la API",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/login": {
      "post": {
        "operationId": "loginBifarma",
        "summary": "Probar login contra Bifarma sin devolver credenciales",
        "responses": {
          "200": {
            "description": "Resultado del intento de login",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObject"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/reports-menu": {
      "get": {
        "operationId": "getReportsMenu",
        "summary": "Leer el menu privado de informes de Bifarma",
        "responses": {
          "200": {
            "description": "Menu de informes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObject"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/report-debug/{code}": {
      "get": {
        "operationId": "debugReport",
        "summary": "Depurar metadatos de un informe por codigo",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Codigo del informe, por ejemplo UN.080.NEW01"
          }
        ],
        "responses": {
          "200": {
            "description": "Metadatos detectados",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObject"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/report-open/{code}": {
      "get": {
        "operationId": "openReport",
        "summary": "Abrir un informe y devolver una vista previa de texto",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Codigo del informe, por ejemplo UN.080.NEW01"
          }
        ],
        "responses": {
          "200": {
            "description": "Resultado de apertura del informe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObject"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/report-form-debug/{code}": {
      "get": {
        "operationId": "debugReportForm",
        "summary": "Investigar campos y callbacks del formulario de un informe",
        "description": "Abre el informe y analiza el HTML para localizar inputs hidden, inputs visibles, selects, textareas, campos relacionados con fechas, oficina, vendedor, farmacia y GLP1, controles DevExpress y callbacks de actualizacion.",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Codigo del informe, por ejemplo UN.080.NEW01"
          }
        ],
        "responses": {
          "200": {
            "description": "Analisis del formulario del informe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportFormDebugResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/report-data-debug/{code}": {
      "get": {
        "operationId": "debugReportData",
        "summary": "Diagnosticar datos, filtros y filas devueltas por un informe",
        "description": "Abre el informe, aplica filtros opcionales y devuelve señales de diagnóstico: filtros internos, si Bifarma responde sin datos, candidatos CN, filas DevExpress y resumen de extracción.",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Codigo del informe, por ejemplo UN.080.NEW01"
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "description": "Fecha desde en formato YYYY-MM-DD"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "description": "Fecha hasta en formato YYYY-MM-DD"
          },
          {
            "name": "office",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Oficina del informe, por ejemplo DEMO"
          },
          {
            "name": "seller",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Vendedor del informe, por ejemplo ROSA"
          },
          {
            "name": "max_rows",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            },
            "description": "Numero maximo de filas de muestra"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Pagina del grid DevExpress a consultar. La primera pagina es 1."
          }
        ],
        "responses": {
          "200": {
            "description": "Diagnostico de datos del informe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObject"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/report-data/{code}": {
      "get": {
        "operationId": "getReportData",
        "summary": "Extraer datos basicos de un informe",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Codigo del informe, por ejemplo UN.080.NEW01"
          },
          {
            "name": "max_rows",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            },
            "description": "Numero maximo de filas a devolver"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Pagina del grid DevExpress a consultar. La primera pagina es 1."
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "description": "Fecha desde en formato YYYY-MM-DD"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "description": "Fecha hasta en formato YYYY-MM-DD"
          },
          {
            "name": "office",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Oficina del informe, por ejemplo DEMO"
          },
          {
            "name": "seller",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Vendedor del informe, por ejemplo ROSA"
          }
        ],
        "responses": {
          "200": {
            "description": "Datos extraidos del informe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObject"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/report-efg-summary/{code}": {
      "get": {
        "operationId": "getEfgSummary",
        "summary": "Calcular resumen de ventas EFG de un informe",
        "description": "Recorre una o varias paginas del informe filtrado y calcula ventas EFG, unidades EFG, margen EFG, porcentaje sobre ventas totales, rankings por producto, rankings por laboratorio y posibles riesgos de stock.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Codigo del informe, por ejemplo UN.080.NEW01"
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "description": "Fecha desde en formato YYYY-MM-DD"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "description": "Fecha hasta en formato YYYY-MM-DD"
          },
          {
            "name": "office",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Oficina del informe, por ejemplo DEMO"
          },
          {
            "name": "seller",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Vendedor del informe, por ejemplo ROSA"
          },
          {
            "name": "start_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Pagina inicial del grid DevExpress. Normalmente usa 1."
          },
          {
            "name": "max_pages",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 25,
              "minimum": 1,
              "maximum": 400
            },
            "description": "Numero maximo de paginas a recorrer. Para informe completo puede usarse 348 si el informe lo indica."
          },
          {
            "name": "max_rows_per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 200,
              "minimum": 1,
              "maximum": 500
            },
            "description": "Numero maximo de filas a leer por pagina."
          },
          {
            "name": "require_cn_medicine_prefix",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            },
            "description": "Si es true, cuenta solo productos EFG cuyo CN empieza por 6, 7, 8 o 9."
          },
          {
            "name": "top_limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 50
            },
            "description": "Numero de elementos que se devuelven en los rankings."
          }
        ],
        "responses": {
          "200": {
            "description": "Resumen calculado de ventas EFG",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObject"
                }
              }
            }
          }
        }
      }
    },
    "/report-export/{code}": {
      "get": {
        "operationId": "exportReport",
        "summary": "Exportar datos extraidos de un informe",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Codigo del informe, por ejemplo UN.080.NEW01"
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "csv",
                "xlsx",
                "pdf"
              ],
              "default": "xlsx"
            },
            "description": "Formato de exportacion"
          },
          {
            "name": "max_rows",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 500
            },
            "description": "Numero maximo de filas a exportar"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Pagina del grid DevExpress a exportar. La primera pagina es 1."
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "description": "Fecha desde en formato YYYY-MM-DD"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "description": "Fecha hasta en formato YYYY-MM-DD"
          },
          {
            "name": "office",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Oficina del informe, por ejemplo DEMO"
          },
          {
            "name": "seller",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Vendedor del informe, por ejemplo ROSA"
          }
        ],
        "responses": {
          "200": {
            "description": "Archivo exportado",
            "content": {
              "text/csv": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/report-export-debug/{code}": {
      "get": {
        "operationId": "debugReportExport",
        "summary": "Depurar botones y callbacks de exportacion de un informe",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Codigo del informe, por ejemplo UN.080.NEW01"
          }
        ],
        "responses": {
          "200": {
            "description": "Informacion de depuracion de exportacion",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericObject"
                }
              }
            }
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/report-efg-summary-job/{code}": {
      "get": {
        "operationId": "startEfgSummaryJob",
        "summary": "Iniciar calculo EFG en segundo plano",
        "description": "Crea un trabajo en segundo plano para calcular el resumen EFG. Devuelve job_id inmediatamente. Luego consulta getEfgSummaryJobStatus con ese job_id.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Codigo del informe, por ejemplo UN.080.NEW01"
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "description": "Fecha desde en formato YYYY-MM-DD"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "description": "Fecha hasta en formato YYYY-MM-DD"
          },
          {
            "name": "office",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Oficina del informe, por ejemplo DEMO"
          },
          {
            "name": "seller",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Vendedor del informe, por ejemplo ROSA"
          },
          {
            "name": "start_page",
            "in": "query",
